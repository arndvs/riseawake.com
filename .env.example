# Sanity CMS — required for content queries and Studio
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-07-10
SANITY_API_TOKEN=sky...
SANITY_API_READ_TOKEN=ske...

# Site URL — used for canonical URLs, sitemaps, OG metadata
NEXT_PUBLIC_SITE_URL=https://riseawake.com

# RISE Render — AI production studio
NEXT_PUBLIC_GENERATION_ENABLED=true

# Clerk — authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/studio
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/studio/render
CLERK_FRONTEND_API_URL=https://xxxx.clerk.accounts.dev

# Convex
NEXT_PUBLIC_CONVEX_URL=https://necessary-xxxx.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://necessary-xxxx.convex.site

# ImageKit
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/...
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_...
IMAGEKIT_PRIVATE_KEY=private_...

# Resend — transactional email (https://resend.com/api-keys)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=RISE <careers@riseawake.com>
RESEND_NOTIFY_EMAIL=careers@riseawake.com