# Sanity CMS — required for content queries and Studio
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-07-10
SANITY_API_TOKEN=skyxxx
SANITY_API_READ_TOKEN=skexxxx

# Site URL — used for canonical URLs, sitemaps, OG metadata
NEXT_PUBLIC_SITE_URL=https://riseawake.com

# RISE Render — AI production studio
NEXT_PUBLIC_GENERATION_ENABLED=true

# Clerk — authentication (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/studio
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/studio/render