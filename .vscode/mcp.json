{
  "servers": {
    "sanity": {
      "type": "http",
      "url": "https://mcp.sanity.io"
    },
    "imagekit_api": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://api-mcp.imagekit.in/sse"
      ]
    },
    "convex-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "convex@latest",
        "mcp",
        "start"
      ]
    }
  }
}